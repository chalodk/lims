{
  "name": "LIMS — Notificaciones por Correo",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Recibir notificacion",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "lims-notificaciones",
        "options": {}
      },
      "webhookId": "lims-notificaciones"
    },
    {
      "id": "send-email",
      "name": "Enviar por Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [550, 300],
      "parameters": {
        "resource": "message",
        "operation": "send",
        "messageType": "html",
        "toRecipients": "={{ $json.body.to_email }}",
        "subject": "={{ $json.body.subject }}",
        "html": "={{ $json.body.html }}"
      }
    }
  ],
  "connections": {
    "Recibir notificacion": {
      "main": [[{ "node": "Enviar por Gmail", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner"
  },
  "pinData": {},
  "versionId": "10.0.0"
}
